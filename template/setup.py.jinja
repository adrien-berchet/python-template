"""Setup for the {{ distribution_name }} package."""{% if repository_provider == 'gitlab' %}
import importlib.util{% endif %}
from pathlib import Path

from setuptools import find_namespace_packages
from setuptools import setup{% if repository_provider == 'gitlab' %}

spec = importlib.util.spec_from_file_location(
    "{{ package_name }}.version",
    "{{ package_name }}/version.py",
)
module = importlib.util.module_from_spec(spec)
spec.loader.exec_module(module)
VERSION = module.VERSION{% endif %}

reqs = ["click"]

doc_reqs = [
    "m2r2",
    "sphinx",
    "sphinx-bluebrain-theme",
    "sphinx-click",
]

test_reqs = [
    "mock",
    "pytest",
    "pytest-click",
    "pytest-cov",
    "pytest-html",
]

setup(
    name="{{ distribution_name }}",
    author="{{ author_name }}",{% if repository_provider == 'gitlab' %}
    author_email="{{ author_email }}",{% endif %}
    description="{{ project_description }}",
    long_description=Path("README.md").read_text(encoding="utf-8"),
    long_description_content_type="text/markdown",
    url="{{ project_url }}",
    project_urls={
        "Tracker": "{{ tracker_url }}",
        "Source": "{{ download_url }}",
    },
    license="{{ copyright_license }}",
    packages=find_namespace_packages(include=["{{ package_name }}*"]),
    python_requires={% if support_py37 %}">=3.7"{% else %}">=3.8"{% endif %},{% if repository_provider == 'gitlab' %}
    version=VERSION,{% else %}
    use_scm_version=True,
    setup_requires=[
        "setuptools_scm",
    ],{% endif %}
    install_requires=reqs,
    extras_require={
        "docs": doc_reqs,
        "test": test_reqs,
    },
    entry_points={
        "console_scripts": [
            "{{ distribution_name }}={{ package_name }}.cli:main",
        ],
    },
    include_package_data=True,
    classifiers=[
        # TODO: Update to relevant classifiers
        "Development Status :: 2 - Pre-Alpha",
        "Intended Audience :: Education",
        "Intended Audience :: Science/Research",
        "Programming Language :: Python",
        "Programming Language :: Python :: 3",{% if support_py37 %}
        "Programming Language :: Python :: 3.7",{% endif %}
        "Programming Language :: Python :: 3.8",
        "Programming Language :: Python :: 3.9",
        "Topic :: Scientific/Engineering :: Bio-Informatics",
    ],
)
