name: Run tests

on:
  workflow_call:
    inputs:
      python-version:
        type: string
        description: Python version to test with
        required: true
      runs-on:
        type: string
        description: Runner image to use
        default: ubuntu-latest

jobs:
  run:
    runs-on: {% raw %}${{ inputs.runs-on }}{% endraw %}
    permissions:
      contents: read
      checks: write

    steps:
      - uses: actions/checkout@v7
        with:
          fetch-depth: 0

      - name: Set up Python {% raw %}${{ inputs.python-version }}{% endraw %}
        uses: actions/setup-python@v6
        with:
          python-version: {% raw %}${{ inputs.python-version }}{% endraw %}

      - name: Install uv
        uses: astral-sh/setup-uv@v7

      - name: Get current month
        id: date
        run: echo "date=$(date +'%Y-%m')" >> $GITHUB_OUTPUT

      - name: Cache tox and pre-commit environments
        uses: actions/cache@v6
        with:
          path: |
            .tox
            ~/.cache/pre-commit
          key: {% raw %}${{ runner.os }}-${{ inputs.python-version }}-${{ steps.date.outputs.date }}-${{ hashFiles('pyproject.toml') }}-${{ hashFiles('tox.ini') }}-${{ hashFiles('.pre-commit-config.yaml') }}{% endraw %}{% if use_uv_lock %}-{% raw %}${{ hashFiles('uv.lock') }}{% endraw %}{% endif %}

      - name: Clear results in tox environments
        run: rm -rf .tox/*/tmp

      - name: Run tox
        run: {% if use_uv_lock %}uv run --locked tox{% else %}uvx --with tox-gh-actions tox{% endif %}

      - name: JUnit Report Action
        uses: mikepenz/action-junit-report@v6.4.2
        if: always()
        with:
          report_paths: 'reports/pytest-*.xml'

      - name: Upload to codecov
        uses: codecov/codecov-action@v7
        with:
          fail_ci_if_error: false
          directory: ./reports
          flags: pytest
          name: py{% raw %}${{ inputs.python-version }}{% endraw %}
          token: {% raw %}${{ secrets.CODECOV_TOKEN }}{% endraw %}

      - name: Upload test artifacts
        uses: actions/upload-artifact@v7
        if: always()
        with:
          name: tests-{% raw %}${{ inputs.runs-on }}-${{ inputs.python-version }}{% endraw %}
          retention-days: 4
          path: |
            .tox/py*/tmp
            reports
