{
    "output": "CHANGELOG.md",
    "template": ".auto-changelog-template.hbs",{% if repository_destination == 'gitlab' %}
    "tagPrefix": "{{ project_name }}-v",{% endif %}
    "commitLimit": false,
    "backfillLimit": false,
    "ignoreCommitPattern": "Release [0-9]+\\.[0-9]+\\.[0-9]+|Update CHANGELOG.*|.*\\[skip-changelog\\].*|\\[pre-commit.ci\\]",
    "commitUrl": "https://bbpgitlab.epfl.ch/neuromath/{{ project_name }}/-/commit/{id}",
    "issueUrl": "https://bbpgitlab.epfl.ch/neuromath/{{ project_name }}/issues/{id}",
    "mergeUrl": "https://bbpgitlab.epfl.ch/neuromath/{{ project_name }}/merge-requests/{id}",
    "compareUrl": "https://bbpgitlab.epfl.ch/neuromath/{{ project_name }}/compare/{from}...{to}"
}
