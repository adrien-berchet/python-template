{
    "output": "CHANGELOG.md",
    "template": ".auto-changelog-template.hbs",
    "commitLimit": false,
    "backfillLimit": false,
    "ignoreCommitPattern": "^Release:? [0-9]+\\.[0-9]+\\.[0-9]+( ?\\(#[0-9]+\\))?$|^Update CHANGELOG.*|.*\\[skip-changelog\\].*|^\\[pre-commit.ci\\]|^\\(dependabot\\) .*",
    "commitUrl": "https://github.com/{{ repository_namespace }}/{{ repository_name }}/commit/{id}",
    "issueUrl": "https://github.com/{{ repository_namespace }}/{{ repository_name }}/issues/{id}",
    "mergeUrl": "https://github.com/{{ repository_namespace }}/{{ repository_name }}/pull/{id}",
    "compareUrl": "https://github.com/{{ repository_namespace }}/{{ repository_name }}/compare/{from}..{to}"
}
