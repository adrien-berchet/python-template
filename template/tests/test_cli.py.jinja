"""Tests for the {{ package_name }}.cli module."""

import pytest
from click.testing import CliRunner
from click.testing import Result
from pytest_console_scripts import RunResult
from pytest_console_scripts import ScriptRunner

import {{ package_name }}.__main__
import {{ package_name }}.cli


def test_cli(cli_runner: CliRunner):
    """Test the CLI."""
    result: Result = cli_runner.invoke(
        {{ package_name }}.cli.main,
        [
            "-x",
            "1",
            "-y",
            "2",
        ],
    )
    assert result.exit_code == 0
    assert result.output == "1 + 2 = 3\n"


def test_entry_point(script_runner: ScriptRunner):
    """Test the entry point."""
    ret: RunResult = script_runner.run(["{{ distribution_name }}", "--version"])  # pyright: ignore
    assert ret.success
    assert ret.stdout.startswith("{{ distribution_name }}, version ")
    assert ret.stderr == ""


def test_module_entry_point(capsys: pytest.CaptureFixture[str]) -> None:
    """Test the module entry point."""
    with pytest.raises(SystemExit) as exc_info:
        {{ package_name }}.__main__.run(["--version"])

    assert exc_info.value.code == 0
    captured = capsys.readouterr()
    assert captured.out.startswith("{{ distribution_name }}, version ")
    assert captured.err == ""
