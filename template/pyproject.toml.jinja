{% if use_pyproject_toml %}[project]
name = "{{ distribution_name }}"
authors = [
    { name="{{ author_name }}"{% if repository_provider == 'gitlab' %}, email="{{ author_email }}"{% endif %} }
]
description = "{{ project_description }}"
readme = "README.md"
requires-python = ">=3.8"
license = { text = "{{ copyright_license }}" }
classifiers = [
    # TODO: Update to relevant classifiers
    "Development Status :: 2 - Pre-Alpha",
    "Intended Audience :: Education",
    "Intended Audience :: Science/Research",
    "Programming Language :: Python",
    "Programming Language :: Python :: 3",
    "Programming Language :: Python :: 3.8",
    "Programming Language :: Python :: 3.9",
    "Programming Language :: Python :: 3.10",
    "Programming Language :: Python :: 3.11",
    "Topic :: Scientific/Engineering :: Bio-Informatics",
]
dynamic = ["version"]
dependencies = [
    "click>=7"
]

[project.optional-dependencies]
docs = [
    "m2r2",
    "sphinx<6",
    "sphinx-bluebrain-theme",
    "sphinx-click",
]
test = [
    "mock>=3",
    "pytest>=6",
    "pytest-click>=1",
    "pytest-console-scripts>=1.3",
    "pytest-cov>=3",
    "pytest-html>=2",
]

[project.urls]
Homepage = "{{ project_url }}"
Repository = "{{ download_url }}"
Tracker = "{{ tracker_url }}"

[project.scripts]
{{ distribution_name }} = "{{ package_name }}.cli:main"

[build-system]
requires = [
    "setuptools>=45",{% if repository_provider == 'github' %}
    "setuptools_scm[toml]>=6.2",
]
build-backend = "setuptools.build_meta"

[tool.setuptools_scm]{% else %}
]
build-backend = "setuptools.build_meta"{% endif %}

[tool.setuptools.packages.find]
include = ["{{ package_name }}*"]{% else %}[build-system]
requires = [
    "setuptools>=45",{% if repository_provider == 'github' %}
    "setuptools_scm[toml]>=6.2",
]
build-backend = "setuptools.build_meta"

[tool.setuptools_scm]{% else %}
]
build-backend = "setuptools.build_meta"
{% endif %}{% endif %}

[tool.black]
line-length = 100
target-version = [
    "py38",
    "py39",
    "py310",
    "py311",
]

[tool.pydocstyle]
# ignore the following:
#   - D107: Missing docstring in __init__
add-ignore = [
    "D107",
]
convention = "google"

[tool.isort]
profile = "black"
line_length = 100
force_single_line = true

[tool.pytest.ini_options]
testpaths = [
    "tests",
]
