[base]
name = {{ package_name }}
files = {[base]name} tests docs/source/conf.py setup.py

[tox]
envlist =
    check-packaging
    lint
    docs
    min_versions
    {{ 'py{' }}312,313,314}
    coverage

minversion = 4.20

[testenv]
extras = test
setenv =
    COVERAGE_FILE = {env:COVERAGE_FILE:.coverage-{envname}}
commands =
    pytest \
        --basetemp={envtmpdir} \
        --cov={[base]name} \
        --cov-branch \
        --cov-fail-under=100 \
        --no-cov-on-fail \
        --cov-report term-missing \
        --cov-report html:reports/coverage-{envname} \
        --cov-report xml:reports/coverage-{envname}.xml \
        --html reports/pytest-{envname}.html \
        --junit-xml=reports/pytest-{envname}.xml \
        --self-contained-html \
        --durations 10 \
        --durations-min=2.0 \
        {posargs}

[testenv:check-packaging]
skip_install = true
deps =
    build
    twine
commands =
    python -m build -o {envtmpdir}/dist
    twine check {envtmpdir}/dist/*

[testenv:min_versions]
inherit = ["testenv"]
basepython = python3.12
deps =
    uv
commands_pre =
    uv pip compile \
        --resolution lowest-direct \
        --all-extras \
        --output-file {envtmpdir}/requirements_min.txt \
        pyproject.toml
    uv pip install -r {envtmpdir}/requirements_min.txt
    uv pip freeze

[testenv:lint]
basepython = python3.12
deps =
    prek
commands =
    prek run --all-files

[testenv:format]
basepython = python3.12
skip_install = true
deps =
    codespell
    prek
commands =
    codespell -i 3 -x .codespellignorelines -w {[base]files} README.md CHANGELOG.md docs/source
    prek run --all-files

[testenv:docs]
changedir = docs
extras = docs
allowlist_externals =
    make
# set warnings as errors using the -W sphinx option
commands = make html SPHINXOPTS=-W{% if repository_provider == 'github' %}

[gh-actions]
python =
  3.12: py312, lint
  3.13: py313, check-packaging
  3.14: py314, docs{% endif %}
