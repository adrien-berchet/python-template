[base]
name = {{ package_name }}
files = {[base]name} tests doc/source/conf.py setup.py

[tox]
envlist =
    check-version
    check-packaging
    lint
    docs
    {{ 'py{' }}{% if support_py37 %}37,{% endif %}38,39}

minversion = 3.18

[testenv]
extras = test
setenv =
    PIP_EXTRA_INDEX_URL = https://bbpteam.epfl.ch/repository/devpi/simple
    COVERAGE_FILE = {env:COVERAGE_FILE:.coverage-{envname}}
commands = pytest \
    --basetemp={envtmpdir} \
    --cov={[base]name} \
    --cov-branch \
    --cov-fail-under=100 \
    --no-cov-on-fail \
    --cov-report term-missing \
    --cov-report html:reports/coverage-{envname} \
    --cov-report xml:reports/coverage-{envname}.xml \
    --html reports/pytest-{envname}.html \
    --junit-xml=reports/pytest-{envname}.xml \
    --self-contained-html \
    {posargs}

[testenv:coverage]
skip_install = true
deps = coverage
allowlist_externals = /bin/bash
commands =
    /bin/bash -c 'coverage combine .coverage-py*'
    coverage xml
    coverage report{% if repository_destination == 'gitlab' %}

[testenv:check-version]
skip_install = true
deps = bbp-nse-ci>=0.2.5
commands =
    do_release.py -p . check-version
    do_release.py -p . check-changelog --release-only --path CHANGELOG.md{% endif %}

[testenv:check-packaging]
skip_install = true
deps =
    wheel
    twine
    setuptools_scm[toml]>=3.4
commands =
    python setup.py sdist bdist_wheel -d {envtmpdir}/dist
    twine check {envtmpdir}/dist/*

[testenv:lint]
basepython = python{% if support_py37 %}3.7{% else %}3.8{% endif %}
deps =
    pre-commit
    pylint
commands =
    pre-commit run --all-files --show-diff-on-failure
    pylint -j {env:PYLINT_NPROCS:1} {[base]files}

[testenv:format]
basepython = python{% if support_py37 %}3.7{% else %}3.8{% endif %}
skip_install = true
deps =
    codespell
    pre-commit
commands =
    codespell -i 2 -x .codespellignorelines -w {[base]files} README.md CHANGELOG.md
    pre-commit run --all-files

[testenv:docs]
changedir = doc
extras = docs
allowlist_externals = make
# set warnings as errors using the -W sphinx option
commands = make html SPHINXOPTS=-W

[flake8]
max-line-length = 100
ignore = E203,W503

[pydocstyle]
# ignore the following
#   - D107: Missing docstring in __init__
add-ignore = D107
convention = google
match = '{{ package_name }}\/.*\.py$|tests\/.*\.py$|doc\/source\/conf\.py$|setup\.py$'{% if repository_destination == 'github' %}

[gh-actions]
python ={% if support_py37 %}
  3.7: py37, lint
  3.8: py38, check-packaging{% else %}
  3.8: py38, check-packaging, lint{% endif %}
  3.9: py39, docs{% endif %}
